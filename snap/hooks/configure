#!/bin/bash
#
# configure hook
#
# Validates configuration and drives the reconcile oneshot service:
#   - valid config with snap-name set  -> enable + (re)start reconcile
#   - snap-name unset                  -> stop + disable reconcile
#
set -euo pipefail

err() { echo "error: $*" >&2; }

RECONCILE_SVC="reconcile"

validate_snap_name() {
    local name="$1"
    if [ "${#name}" -gt 40 ]; then
        err "snap-name '$name' is too long (max 40 characters)."; return 1
    fi
    if ! echo "$name" | grep -Eq '^[a-z0-9](-?[a-z0-9])*$'; then
        err "snap-name '$name' is invalid. Names must use lowercase letters,
       digits and single hyphens, and may not start or end with a hyphen."
        return 1
    fi
    if ! echo "$name" | grep -Eq '[a-z]'; then
        err "snap-name '$name' must contain at least one letter."; return 1
    fi
    return 0
}

validate_channel() {
    local channel="$1"
    local risks="stable candidate beta edge"
    IFS='/' read -r p1 p2 p3 extra <<< "$channel"
    if [ -n "${extra:-}" ]; then
        err "channel '$channel' has too many components (expected track/risk/branch)."
        return 1
    fi
    is_risk() { local c="$1" r; for r in $risks; do [ "$c" = "$r" ] && return 0; done; return 1; }
    valid_token() { echo "$1" | grep -Eq '^[a-zA-Z0-9]([a-zA-Z0-9._-]*[a-zA-Z0-9])?$'; }
    case "$channel" in
        */*/*)
            valid_token "$p1" || { err "channel track '$p1' is invalid."; return 1; }
            is_risk "$p2"     || { err "channel risk '$p2' must be one of: $risks."; return 1; }
            valid_token "$p3" || { err "channel branch '$p3' is invalid."; return 1; }
            ;;
        */*)
            valid_token "$p1" || { err "channel track '$p1' is invalid."; return 1; }
            is_risk "$p2"     || { err "channel risk '$p2' must be one of: $risks."; return 1; }
            ;;
        *)
            if is_risk "$channel"; then :;
            elif valid_token "$channel"; then :;
            else err "channel '$channel' is invalid."; return 1; fi
            ;;
    esac
    return 0
}

validate_positive_int() {
    local key="$1" val="$2"
    if ! echo "$val" | grep -Eq '^[1-9][0-9]*$'; then
        err "$key must be a positive integer (got '$val')."; return 1
    fi
    return 0
}

enable_reconcile() {
    if ! snapctl start --enable "$RECONCILE_SVC" 2>/dev/null; then
        snapctl restart "$RECONCILE_SVC" 2>/dev/null || \
            err "warning: could not start ${RECONCILE_SVC} service."
    fi
}

disable_reconcile() {
    snapctl stop --disable "$RECONCILE_SVC" 2>/dev/null || true
}

main() {
    local snap_name channel max_attempts base_delay max_delay

    snap_name="$(snapctl get snap-name || true)"
    channel="$(snapctl get channel || true)"
    max_attempts="$(snapctl get install-max-attempts || true)"
    base_delay="$(snapctl get install-base-delay || true)"
    max_delay="$(snapctl get install-max-delay || true)"

    if [ -n "$snap_name" ]; then
        validate_snap_name "$snap_name" || { err "Rejecting configuration change."; exit 1; }
    fi
    if [ -n "$channel" ]; then
        validate_channel "$channel" || { err "Rejecting configuration change."; exit 1; }
    fi
    if [ -n "$max_attempts" ]; then
        validate_positive_int "install-max-attempts" "$max_attempts" || { err "Rejecting configuration change."; exit 1; }
    fi
    if [ -n "$base_delay" ]; then
        validate_positive_int "install-base-delay" "$base_delay" || { err "Rejecting configuration change."; exit 1; }
    fi
    if [ -n "$max_delay" ]; then
        validate_positive_int "install-max-delay" "$max_delay" || { err "Rejecting configuration change."; exit 1; }
    fi
    if [ -n "$base_delay" ] || [ -n "$max_delay" ]; then
        local eff_base="${base_delay:-3}" eff_max="${max_delay:-60}"
        if [ "$eff_base" -gt "$eff_max" ]; then
            err "install-base-delay ($eff_base) must not exceed install-max-delay ($eff_max)."
            err "Rejecting configuration change."
            exit 1
        fi
    fi

    if [ -n "$snap_name" ]; then
        enable_reconcile
    else
        disable_reconcile
    fi

    exit 0
}

main "$@"
